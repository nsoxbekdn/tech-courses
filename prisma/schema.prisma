// Auth + learning progress. The course catalog itself is static-generated from
// YouTube (src/lib/catalog.generated.ts), so courseId/lessonId here are the
// generated string ids, not foreign keys.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String?  // null for OAuth-only (Google) accounts
  image        String?
  createdAt    DateTime @default(now())

  sessions     Session[]
  enrollments  Enrollment[]
  progress     Progress[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  enrolledAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
}

model Progress {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  lessonId  String
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

// ─── Catalog (synced from YouTube, curated by the owner in Course Studio) ───

model Course {
  id            String   @id // = YouTube playlist id (stable across re-syncs)
  slug          String   @unique

  // Synced from YouTube (overwritten each sync)
  ytTitle       String
  ytDescription String   @default("")
  thumbnail     String   @default("")
  views         Int      @default(0)
  syncedAt      DateTime @default(now())

  // Owner-editable overrides (Course Studio; preserved across syncs)
  published     Boolean  @default(false)
  track         String   @default("OTHER") // CERTIFICATION | CODING | OTHER
  level         String   @default("")
  code          String?
  order         Int      @default(0)
  titleOverride String?
  descOverride  String?
  examInfo      String?  // certification exam details (passing %, fees, format)
  mockTestUrl   String?  // instructor-attached mock test / practice link

  createdAt     DateTime @default(now())
  lessons       Lesson[]
}

model Lesson {
  id        String @id // = `${courseId}_${ytVideoId}` (stable)
  courseId  String
  ytVideoId String
  title     String
  seconds   Int    @default(0)
  views     Int    @default(0)
  position  Int    @default(0)

  course    Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, ytVideoId])
  @@index([courseId])
}

// Admin allowlist (by email, so they can be granted access before signing up).
// The ADMIN_EMAILS env list is the always-on "owner" bootstrap on top of this.
model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  addedBy   String?
  createdAt DateTime @default(now())
}

model Channel {
  id          String   @id @default("singleton")
  title       String   @default("Tech Courses")
  subscribers Int      @default(0)
  totalViews  Int      @default(0)
  videoCount  Int      @default(0)
  syncedAt    DateTime @default(now())
}
